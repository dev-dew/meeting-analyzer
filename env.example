# Database (Neon free: https://neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# Session secret (random 32+ char string)
SESSION_SECRET="your-very-long-random-secret-string-here-min-32-chars"

# ── Speech-to-Text (มีทั้ง 2 keys ใช้งาน 1 key คือ GROQ ส่วน AssemblyAI ไม่ได้ใช้งาน) ──────────────────────

# Groq — ใช้สำหรับ Upload File (ฟรี, https://console.groq.com)
# - รับไฟล์ MP4, WebM, MP3, WAV ฯลฯ อัตโนมัติ
# - ฟรี 1,500 req/วัน
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxx"

# AssemblyAI — ใช้สำหรับ Google Drive URL (ฟรี 5h, https://assemblyai.com)
# - รับ Google Drive URL โดยตรง ไม่ต้องดาวน์โหลดผ่าน server
# - รองรับภาษาไทย + แยกเสียงผู้พูด (Speaker A/B/C)
# - ฟรี 5 ชั่วโมงแรก
# ASSEMBLYAI_API_KEY="your_assemblyai_key_here"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Email Reports (Resend, ฟรี 3,000/เดือน) ─────────────────
# ขอ key ฟรีที่ https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# Email ที่ใช้ส่ง (ต้อง verify domain ใน Resend ก่อน)
EMAIL_FROM="H+ Meeting Analyzer <noreply@yourdomain.com>"

# Admin email รับ report ทุก meeting
ADMIN_EMAIL="admin@hotelplus.asia"

# Secret สำหรับ cron job weekly digest
CRON_SECRET="your-cron-secret-here"
